# 공유 링크 미리보기(og:image) 등 절대 URL — 배포 시 실제 도메인으로 설정
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Redis Cloud (또는 TCP Redis) — Connect 대화상자의 Public URL 권장
# 예: rediss://default:비밀번호@호스트:포트
REDIS_URL=

# URL 대신 분리 입력 (둘 중 하나만 쓰면 됨)
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=default
# REDIS_TLS=true

# TLS 인증서 검증 끄기 (필요할 때만)
# REDIS_TLS_REJECT_UNAUTHORIZED=false
